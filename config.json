{
    "llm": {
        "provider": "nvidia",
        "temperature": 0.2,
        "retries": 3,
        "timeout": 60,
        "providers": {
            "nvidia": {
                "model_name": "meta/llama-3.1-8b-instruct",
                "base_url": "https://integrate.api.nvidia.com/v1"
            },
            "groq": {
                "model_name": "llama-3.3-70b-versatile",
                "base_url": "https://api.groq.com/openai/v1"
            },
            "google": {
                "model_name": "gemma-4-e4b-it"
            },
            "ollama": {
                "model_name": "llama3.1",
                "base_url": "http://localhost:11434"
            }
        }
    },
    "retrieval": {
        "knowledge_cutoff_year": {
            "scifact": 2020,
            "bioasq": 2022,
            "healthfc": 2024
        },
        "dynamic_coins": 3,
        "base_coins_per_source": 1,
        "max_results_per_query": 10,
        "hybrid": {
            "dense_top_k": 20,
            "sparse_top_k": 20,
            "rerank_top_k": 10,
            "max_chunks_per_doc": 10
        },
        "chunking": {
            "chunk_size": 300,
            "overlap": 50
        },
        "dense": {
            "model_name": "medcpt"
        },
        "reranker": {
            "model_name": "ncbi/MedCPT-Cross-Encoder"
        }
    },
    "evaluation": {
        "mode": "api",
        "veracity_model_name": "pritamdeka/PubMedBERT-MNLI-MedNLI"
    }
}