# LLM provider is configured in config.json under llm.provider

# API keys (Note: only NVIDIA NIM is supported among cloud providers. Local Ollama does not require a key).
# GOOGLE_API_KEY="your-google-api-key-here" (Placeholder - currently not supported)
NVIDIA_API_KEY="your-nvidia-api-key-here"
# GROQ_API_KEY="your-groq-api-key-here" (Placeholder - currently not supported)

# Hugging Face token used to download embeddings models
HF_TOKEN="your-huggingface-token-here"

# NCBI API key for PubMed E-Utilities (optional, increases rate limit from 3 to 10 req/sec)
# Register at https://www.ncbi.nlm.nih.gov/account/ to obtain a key
NCBI_API_KEY="your-ncbi-api-key-here"

# --- MongoDB Logging ---
MONGO_URI="mongodb://localhost:27017"
MONGO_DB_NAME="med_fact_check"
MONGO_LOGGING_ENABLED=true