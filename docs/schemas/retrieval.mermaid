%%{init: {"themeVariables": {"fontSize": "32px", "fontFamily": "arial", "edgeLabelBackground": "#ffffff"}}}%%
graph LR
    %% Definizione dei nodi
    Start[" "]
    Router[" "]
    
    subgraph RetrievalTeam ["&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Retrieval Team&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"]
        SourceSelector["fa:fa-brain (LLM)<br><b>source_selector</b>"]
        Downloader["fa:fa-download (Agent)<br><b>downloader_agent</b>"]
        HybridRetriever["fa:fa-filter<br><b>hybrid_retriever</b>"]
        
        %% Componenti/Tool interni più piccoli
        subgraph ToolsGroup [" "]
            direction TB
            Dense(["fa:fa-cube<br><b>Dense Retrieval</b>"])
            Sparse(["fa:fa-list<br><b>Sparse (BM25)</b>"])
            Reranker(["fa:fa-sort-amount-down<br><b>Cross-Encoder</b>"])
            
            MedCPTQuery("ncbi/<br>MedCPT-Query-Encoder")
            MedCPTArticle("ncbi/<br>MedCPT-Article-Encoder")
            MedCPTCross("ncbi/<br>MedCPT-Cross-Encoder")
        end
    end
    
    End[" "]

    %% Fonti Esterne
    WebSources(["fa:fa-cloud<br><b>WebSources</b><br>(PubMed, EuropePMC, UniProt)"])

    %% Connessioni principali con i tipi di dato
    Start -- "<b>Verifiable<br>SubClaim</b>" --> Router
    Router --> SourceSelector
    Router --> HybridRetriever
    SourceSelector -- "<b>Dict[Source,<br>Coins]</b>" --> Downloader
    
    %% Interazione con il Web
    Downloader <-.->|"<b>HTTP / API</b>"| WebSources
    
    Downloader -- "<b>List[Downloaded<br>Chunk]</b>" --> HybridRetriever
    
    %% Connessioni ai tool
    HybridRetriever <-.-> Dense
    HybridRetriever <-.-> Sparse
    HybridRetriever <-.-> Reranker
    
    %% Connessioni ai modelli
    Dense <-.-> MedCPTQuery
    Dense <-.-> MedCPTArticle
    Reranker <-.-> MedCPTCross

    %% Output
    HybridRetriever -- "<b>Top K Chunks [List]</b>" --> End

    %% Stili paper-like (Scala di grigi / B&N per articoli accademici)
    classDef invisible fill:none,stroke:none,color:none;
    classDef process fill:#f5f5f5,stroke:#000000,stroke-width:1px,color:#000000,font-size:32px;
    classDef algorithmic fill:#e0e0e0,stroke:#000000,stroke-width:1px,stroke-dasharray: 5 5,color:#000000,font-size:32px;
    classDef toolNode fill:#ffffff,stroke:#000000,stroke-width:1px,stroke-dasharray: 2 2,color:#000000,font-size:28px;
    classDef modelNode fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000,font-size:24px;
    classDef webNode fill:#ffffff,stroke:#000000,stroke-width:1px,stroke-dasharray: 4 4,color:#000000,font-size:28px;
    
    %% Assegnazione degli stili
    class Start,End,Router invisible;
    class SourceSelector,Downloader process;
    class HybridRetriever algorithmic;
    class Dense,Sparse,Reranker toolNode;
    class MedCPTQuery,MedCPTArticle,MedCPTCross modelNode;
    class WebSources webNode;

    %% Stili dei subgraph
    style RetrievalTeam fill:none,stroke:#000000,stroke-width:1px,stroke-dasharray: 5 5,color:#000000,font-size:40px,font-weight:bold
    style ToolsGroup fill:none,stroke:none,color:none